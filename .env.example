# ─── WhatsApp Business Cloud API (Meta) ───────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_VERIFY_TOKEN=un_token_secreto_cualquiera_para_verificar_webhook

# Número de WhatsApp de Karla (con código de país, sin +, sin espacios)
KARLA_PHONE_NUMBER=521XXXXXXXXXX

# ─── Ollama (Gemma 4 local) ───────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4

# ─── Google Calendar ──────────────────────────────────────────────────────────
# ID del calendario donde se agendarán las citas (usualmente el email de Karla)
GOOGLE_CALENDAR_ID=karla@ejemplo.com
# Ruta al archivo de credenciales OAuth2 descargado de Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
# Ruta donde se guardará el token de acceso una vez autenticado
GOOGLE_TOKEN_FILE=token.json


# ─── Configuración general ────────────────────────────────────────────────────
# Zona horaria de Karla
TIMEZONE=America/Mexico_City
# Tiempo en minutos de inactividad antes de cerrar una conversación
CONVERSATION_TIMEOUT_MINUTES=60
# Puerto del servidor
PORT=8000
