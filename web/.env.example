# ── Base de datos ─────────────────────────────────────────────
# Railway la inyecta automáticamente al conectar el plugin PostgreSQL.
# Para desarrollo local se usa SQLite por defecto (no es necesario definirla).
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# ── Correo de confirmación ────────────────────────────────────
# Activar envío real de emails (true/false)
SMTP_ENABLED=false

# Servidor SMTP — Gmail recomendado
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=karlasanchez.j@gmail.com

# Contraseña de aplicación de Gmail
# (Cuenta Google → Seguridad → Verificación en dos pasos → Contraseñas de aplicaciones)
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Nombre que aparece como remitente
SMTP_FROM=Karla Zermeño — Psicóloga
